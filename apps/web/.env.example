# Production site URL — required for canonical URLs, OG tags, sitemap, robots, llms.txt
NEXT_PUBLIC_SITE_URL=https://steprs.dev

# Optional: enable AI Edit tab locally only. Leave unset on production.
# NEXT_PUBLIC_ENABLE_EDIT=true

# Optional: Vercel Analytics + Speed Insights (private deployments only).
# Leave unset on the public site.
# NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Optional: Google Search Console site verification token
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
